# Application Kconfig for the 802.15.4 <-> WiFi tunnel bridge.

source "Kconfig.zephyr"

menu "Bridge configuration"

config BRIDGE_DIRECT_HOST
	string "Optional IPv4 literal of the peer's direct (port-forwarded) address"
	default ""
	help
	  When non-empty, the bridge tries to connect here first on every
	  reconnect, falling back to BRIDGE_RELAY_HOST if the direct dial
	  fails. Empty means relay-only (the original behavior).

	  Use when one peer has a static public IP plus port-forwarding
	  pointing at the listener-mode bridge on the other side.

config BRIDGE_DIRECT_PORT
	int "TCP port of the peer's direct address"
	default 47000
	range 1 65535
	help
	  Only consulted when BRIDGE_DIRECT_HOST is non-empty.

config BRIDGE_DIRECT_PROBE_PERIOD_S
	int "Re-probe period for direct path while on relay (seconds)"
	default 300
	range 30 3600
	help
	  While the tunnel is running on relay, retry the direct path this
	  often. On a successful direct connect the relay socket is closed
	  and traffic switches over. Only consulted when BRIDGE_DIRECT_HOST
	  is non-empty.

config BRIDGE_TUNNEL_ID
	string "Tunnel identifier shared with the peer bridge"
	default "default"
	help
	  Both bridges in the same logical tunnel must use the same value.
	  Sent in the HELLO message so the relay can pair them.

config BRIDGE_15_4_CHANNEL
	int "IEEE 802.15.4 channel"
	default 23
	range 11 26
	help
	  Pick one that does not overlap with the WiFi channel in use
	  (15, 20, 25, 26 vs WiFi 1/6/11).

config BRIDGE_15_4_PAN_ID
	hex "IEEE 802.15.4 PAN ID"
	default 0xBEEF

config BRIDGE_RX_SLAB_DEPTH
	int "Depth of the radio RX frame slab"
	default 16
	range 4 64
	help
	  Number of in-flight 802.15.4 RX frames buffered in radio_154.c
	  between the driver callback and the radio_to_tunnel_thread.

endmenu

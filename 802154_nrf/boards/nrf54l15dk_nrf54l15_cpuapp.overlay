/* SRAM size override -- ported from sta/boards/lab8.overlay.
 * Forces the cpuapp SRAM region to the full 256 KB so the WiFi
 * stack has room. Without this, the default split for nRF54L15 may
 * leave too little for the supplicant + nrf70 buffers.
 */

&cpuapp_sram {
	reg = <0x20000000 DT_SIZE_K(256)>;
	ranges = <0x0 0x20000000 DT_SIZE_K(256)>;
};
